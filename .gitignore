# ============================================================
# ProTube Saver — .gitignore
# ============================================================

# --- USER DATA — never commit ---
# data/ contains the user's library, settings.json, downloaded videos,
# thumbnails, transcoded cache, yt-dlp runtime, and logs. All personal.
# Every running install creates its own data/ folder next to the exe.
data/

# --- BUILD OUTPUT ---
dist/
build/

# --- VIRTUALENV ---
.venv/
venv/

# --- RELEASE ARTIFACTS ---
# Packaged installers are uploaded to GitHub Releases / the landing site,
# not tracked in git (they exceed the 100 MB file limit anyway).
*.dmg
*.zip

# --- PYTHON BYTECODE ---
__pycache__/
*.pyc
*.pyo

# --- LARGE BUILD PREREQS ---
# ffmpeg.exe (~94 MB) and ffprobe.exe (~141 MB) both exceed GitHub's 100 MB
# per-file limit. Drop fresh copies from gyan.dev into assets/ before running
# pyinstaller. icon.ico is small and stays committed.
assets/ffmpeg.exe
assets/ffprobe.exe
# Mac equivalents — grab static universal2 builds from evermeet.cx.
assets/mac/ffmpeg
assets/mac/ffprobe

# --- DEV/TEST SCREENSHOTS ---
# May contain personal library/queue contents. Not source.
screenshots/

# --- LOCAL CLAUDE CODE CONFIG ---
.claude/

# --- RECOVERY / BACKUP FILES ---
# Auto-generated by the settings recovery path; not meant to be tracked.
*.corrupt
*.corrupt.*
*.empty-*
*.bak
*.tmp

# --- OS NOISE ---
Thumbs.db
.DS_Store
desktop.ini

# --- EDITORS ---
.vscode/
.idea/
*.swp
*~
